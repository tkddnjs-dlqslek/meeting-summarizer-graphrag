ANTHROPIC_API_KEY=sk-ant-...

NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=xxxxxxxx
NEO4J_PASSWORD=...
NEO4J_DATABASE=xxxxxxxx

WHISPER_MODEL=./models/whisper-medium
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en

OBSIDIAN_VAULT_PATH=./MeetingNotes

# ── Notion (선택적) ──────────────────────────────────────────────
# NOTION_ENABLED=true일 때만 Obsidian과 병행하여 Notion database에도 저장.
# 첫 실행 시 parent page 아래에 database가 자동 생성되고 ID는 ./notion_db_id.json에 캐시됩니다.
NOTION_ENABLED=false
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
# (선택) 이미 만든 database를 쓰고 싶을 때만. 비우면 자동 생성됨.
NOTION_DATABASE_ID=
